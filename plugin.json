{
  "workflow": {
    "nodes": [
      {
        "id": "plugin-metadata",
        "type": "modifier",
        "position": {
          "x": 240,
          "y": 160
        },
        "data": {
          "modifier": {
            "name": "Dislocation Analysis",
            "key": "opendxa",
            "icon": "HiCube",
            "author": "Rodolfo Herrera",
            "license": "MIT",
            "version": "1.0.5",
            "homepage": "https://github.com/rodyherrera/Volterra",
            "description": "Analisis de dislocaciones a partir del algoritmo de identificacion de estructura seleccionado por el usuario."
          }
        }
      },
      {
        "id": "plugin-arguments",
        "type": "arguments",
        "position": {
          "x": 528,
          "y": 208
        },
        "data": {
          "arguments": {
            "arguments": [
              {
                "argument": "structure_analysis_plugin",
                "type": "pluginReference",
                "label": "Structure Analysis Algorithm",
                "required": true,
                "showPluginConfiguration": true,
                "pluginReferenceFilterKeys": [
                  "polyhedral-template-matching",
                  "adaptive-common-neighbor-analysis"
                ],
                "pluginReferenceMappings": [
                  {
                    "sourceArgument": "reference_topology",
                    "targetArgument": "crystal_structure",
                    "targetPluginKey": "polyhedral-template-matching",
                    "valueMap": {
                      "fcc": "FCC",
                      "bcc": "BCC",
                      "hcp": "HCP",
                      "sc": "SC",
                      "cubic_diamond": "CUBIC_DIAMOND",
                      "hex_diamond": "HEX_DIAMOND"
                    }
                  },
                  {
                    "sourceArgument": "reference_topology",
                    "targetArgument": "crystal_structure",
                    "targetPluginKey": "adaptive-common-neighbor-analysis",
                    "valueMap": {
                      "fcc": "FCC",
                      "bcc": "BCC",
                      "hcp": "HCP",
                      "sc": "SC",
                      "cubic_diamond": "CUBIC_DIAMOND",
                      "hex_diamond": "HEX_DIAMOND"
                    }
                  }
                ]
              },
              {
                "argument": "reference_topology",
                "type": "select",
                "label": "Reference Topology",
                "default": "fcc",
                "options": [
                  {
                    "key": "fcc",
                    "label": "FCC"
                  },
                  {
                    "key": "bcc",
                    "label": "BCC"
                  },
                  {
                    "key": "hcp",
                    "label": "HCP"
                  },
                  {
                    "key": "sc",
                    "label": "SC"
                  },
                  {
                    "key": "cubic_diamond",
                    "label": "Cubic Diamond"
                  },
                  {
                    "key": "hex_diamond",
                    "label": "Hexagonal Diamond"
                  }
                ]
              },
              {
                "argument": "max_trial_circuit_size",
                "type": "number",
                "label": "Max Trial Circuit Size",
                "default": 14,
                "min": 1,
                "step": 1
              },
              {
                "argument": "circuit_stretchability",
                "type": "number",
                "label": "Circuit Stretchability",
                "default": 9,
                "min": 1,
                "step": 1
              },
              {
                "argument": "line_smoothing_level",
                "type": "number",
                "label": "Line Smoothing Level",
                "default": 1,
                "min": 0,
                "step": 0.1
              },
              {
                "argument": "line_point_interval",
                "type": "number",
                "label": "Line Point Interval",
                "default": 2.5,
                "min": 0,
                "step": 0.1
              }
            ]
          }
        }
      },
      {
        "id": "trajectory-context",
        "type": "context",
        "position": {
          "x": 816,
          "y": 160
        },
        "data": {
          "context": {
            "source": "trajectory_dumps"
          }
        }
      },
      {
        "id": "foreach-trajectory-dumps",
        "type": "forEach",
        "position": {
          "x": 1088,
          "y": 208
        },
        "data": {
          "forEach": {
            "iterableSource": "{{ trajectory-context.trajectory_dumps }}"
          }
        }
      },
      {
        "id": "structure-analysis-plugin",
        "type": "plugin-node",
        "position": {
          "x": 1392,
          "y": 208
        },
        "data": {
          "pluginNode": {
            "executionMode": "argumentReference",
            "argumentReference": "structure_analysis_plugin",
            "outputPathMode": "parent"
          }
        }
      },
      {
        "id": "analysis-entrypoint",
        "type": "entrypoint",
        "position": {
          "x": 1696,
          "y": 208
        },
        "data": {
          "entrypoint": {
            "type": "packaged-executable",
            "binary": "opendxa-plugin.zip",
            "binaryObjectPath": "__UPLOAD_BINARY_OBJECT_PATH__",
            "binaryFileName": "opendxa-plugin.zip",
            "entrypointScript": "bin/opendxa",
            "requirementsFile": "",
            "arguments": "{{ foreach-trajectory-dumps.outputPath }}_annotated.dump {{ foreach-trajectory-dumps.outputPath }} --clusters_table {{ foreach-trajectory-dumps.outputPath }}_clusters.table --clusters_transitions {{ foreach-trajectory-dumps.outputPath }}_cluster_transitions.table --lattice_dir {{ analysis-entrypoint.projectPath }}/share/volt/lattices --export_interface_mesh true --export_structure_identification true --export_coherent_crystalline_regions true {{ plugin-arguments.as_str }}",
            "timeout": -1,
            "inputs": [
              {
                "name": "annotatedDump",
                "required": true,
                "description": "Per-atom annotated LAMMPS dump produced by an upstream structure-identification step."
              },
              {
                "name": "clustersTable",
                "required": true,
                "cliFlag": "--clusters_table",
                "description": "Cluster graph table produced by an upstream structure-identification step (PTM/ACNA/PSM)."
              },
              {
                "name": "clustersTransitions",
                "required": true,
                "cliFlag": "--clusters_transitions",
                "description": "Cluster transitions table produced by an upstream structure-identification step."
              }
            ]
          }
        }
      },
      {
        "id": "primary-exposure",
        "type": "exposure",
        "position": {
          "x": 2016,
          "y": 208
        },
        "data": {
          "exposure": {
            "name": "Dislocations",
            "icon": "HiCube",
            "results": "dislocations.msgpack",
            "iterable": ""
          }
        }
      },
      {
        "id": "primary-export",

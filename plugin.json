                }
            },
            {
                "id": "crystalline-coherent-regions-export",
                "type": "export",
                "position": {
                    "x": 2336,
                    "y": 888
                },
                "data": {
                    "export": {
                        "exporter": "AtomisticExporter",
                        "type": "glb"
                    }
                }
            },
            {
                "id": "burgers-counts-chart-exposure",
                "type": "exposure",
                "position": {
                    "x": 1712,
                    "y": 848
                },
                "data": {
                    "exposure": {
                        "name": "Burgers Segment Counts",
                        "icon": "HiChartBar",
                        "results": "dislocation_summary.parquet",
                        "iterable": "",
                        "hasListing": false
                    }
                }
            },
            {
                "id": "burgers-counts-chart-export",
                "type": "export",
                "position": {
                    "x": 2032,
                    "y": 848
                },
                "data": {
                    "export": {
                        "exporter": "ChartExporter",
                        "type": "chart-png",
                        "options": {
                            "xAxisKey": "burgers_counts.burgers_vector",
                            "yAxisKey": "burgers_counts.segment_count",
                            "chartType": "bar",
                            "title": "Dislocation segments by Burgers vector",
                            "xAxisLabel": "Burgers vector",
                            "yAxisLabel": "Segments",
                            "backgroundColor": "#ffffff",
                            "lineColor": "#2563eb",
                            "fillColor": "rgba(37, 99, 235, 0.35)",
                            "showLegend": false,
                            "showGrid": true
                        }
                    }
                }
            },

                    "y": 1008
                },
                "data": {
                    "exposure": {
                        "name": "Network Statistics",
                        "icon": "HiChartBar",
                        "results": "dislocation_summary.parquet",
                        "iterable": "",
                        "hasListing": true
                    }
                }
            }
        ],
        "edges": [
            {
                "id": "edge-metadata-arguments",
                "source": "plugin-metadata",
                "sourceHandle": "output",
                "target": "plugin-arguments",
                "targetHandle": "input"
            },
            {
                "id": "edge-arguments-context",
                "source": "plugin-arguments",
                "sourceHandle": "output",
                "target": "trajectory-context",
                "targetHandle": "input"
            },
            {
                "id": "edge-context-foreach",
                "source": "trajectory-context",
                "sourceHandle": "output",
                "target": "foreach-trajectory-dumps",
                "targetHandle": "input"
            },
            {
                "id": "edge-foreach-entrypoint",
                "source": "foreach-trajectory-dumps",
                "sourceHandle": "output",
                "target": "analysis-entrypoint",
                "targetHandle": "input"
            },
            {
                "id": "edge-entrypoint-primary-exposure",
                "source": "analysis-entrypoint",
                "sourceHandle": "output",
                "target": "primary-exposure",
                "targetHandle": "input"
            },
            {
                "id": "edge-primary-exposure-primary-export",
                "source": "primary-exposure",
                "sourceHandle": "output",
                "target": "primary-export",
                "targetHandle": "input"

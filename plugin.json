                    "x": 2016,
                    "y": 752
                },
                "data": {
                    "exposure": {
                        "name": "Structure Identification",
                        "icon": "HiCube",
                        "results": "atoms.parquet",
                        "iterable": ""
                    }
                }
            },
            {

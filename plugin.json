{
    "workflow": {
        "nodes": [
            {
                "id": "plugin-metadata",
                "type": "modifier",
                "position": {
                    "x": 240,
                    "y": 160
                },
                "data": {
                    "modifier": {
                        "name": "Dislocation Analysis",
                        "key": "opendxa",
                        "icon": "HiCube",
                        "author": "Rodolfo Herrera",
                        "license": "MIT",
                        "version": "2.0.4",
                        "homepage": "https://github.com/rodyherrera/Volterra",
                        "description": "Analisis de dislocaciones a partir del algoritmo de identificacion de estructura seleccionado por el usuario."
                    }
                }
            },
            {
                "id": "plugin-arguments",
                "type": "arguments",
                "position": {
                    "x": 528,
                    "y": 208
                },
                "data": {
                    "arguments": {
                        "arguments": [
                            {
                                "argument": "clusters_table",
                                "type": "string",
                                "label": "Clusters Table",
                                "inferFromContext": true,
                                "plugins": [
                                    "polyhedral-template-matching",
                                    "adaptive-common-neighbor-analysis",
                                    "pattern-structure-matching"
                                ]
                            },
                            {
                                "argument": "clusters_transitions",
                                "type": "string",
                                "label": "Clusters Transitions",
                                "inferFromContext": true,
                                "plugins": [
                                    "polyhedral-template-matching",
                                    "adaptive-common-neighbor-analysis",
                                    "pattern-structure-matching"
                                ]
                            },
                            {
                                "argument": "neighbor_lattice",
                                "type": "string",
                                "label": "Neighbor Lattice",
                                "inferFromContext": true,
                                "plugins": [
                                    "polyhedral-template-matching",
                                    "adaptive-common-neighbor-analysis",
                                    "pattern-structure-matching"
                                ]
                            },
                            {
                                "argument": "reference_topology",
                                "type": "select",
                                "label": "Reference Topology",
                                "default": "fcc",
                                "options": [
                                    {
                                        "key": "fcc",
                                        "label": "FCC"
                                    },
                                    {
                                        "key": "bcc",
                                        "label": "BCC"
                                    },
                                    {
                                        "key": "hcp",
                                        "label": "HCP"
                                    },
                                    {
                                        "key": "sc",
                                        "label": "SC"
                                    },
                                    {
                                        "key": "cubic_diamond",
                                        "label": "Cubic Diamond"
                                    },
                                    {
                                        "key": "hex_diamond",
                                        "label": "Hexagonal Diamond"
                                    }
                                ]
                            },
                            {
                                "argument": "max_trial_circuit_size",
                                "type": "number",
                                "label": "Max Trial Circuit Size",
                                "default": 14,
                                "min": 1,
                                "step": 1
                            },
                            {
                                "argument": "circuit_stretchability",
                                "type": "number",
                                "label": "Circuit Stretchability",
                                "default": 9,
                                "min": 1,
                                "step": 1
                            },
                            {
                                "argument": "line_smoothing_level",
                                "type": "number",
                                "label": "Line Smoothing Level",
                                "default": 1,
                                "min": 0,
                                "step": 0.1
                            },
                            {
                                "argument": "line_point_interval",
                                "type": "number",
                                "label": "Line Point Interval",
                                "default": 2.5,
                                "min": 0,
                                "step": 0.1
                            }
                        ]
                    }
                }
            },
            {
                "id": "trajectory-context",
                "type": "context",
                "position": {
                    "x": 816,
                    "y": 160
                },
                "data": {
                    "context": {
                        "source": "trajectory_dumps"
                    }
                }
            },
            {
                "id": "foreach-trajectory-dumps",
                "type": "forEach",
                "position": {
                    "x": 1088,
                    "y": 208
                },
                "data": {
                    "forEach": {
                        "iterableSource": "{{ trajectory-context.trajectory_dumps }}"
                    }
                }
            },
            {
                "id": "analysis-entrypoint",
                "type": "entrypoint",
                "position": {
                    "x": 1696,
                    "y": 208
                },
                "data": {
                    "entrypoint": {
                        "type": "packaged-executable",
                        "binary": "opendxa-plugin.zip",
                        "binaryObjectPath": "__UPLOAD_BINARY_OBJECT_PATH__",
                        "binaryFileName": "opendxa-plugin.zip",
                        "entrypointScript": "bin/opendxa",
                        "requirementsFile": "",
                        "arguments": "{{ foreach-trajectory-dumps.currentValue.path }} {{ foreach-trajectory-dumps.outputPath }} --lattice_dir {{ analysis-entrypoint.projectPath }}/share/volt/lattices --export_interface_mesh true --export_structure_identification true --export_coherent_crystalline_regions true {{ plugin-arguments.as_str }}",
                        "timeout": -1,
                        "inputs": [
                            {
                                "name": "annotatedDump",
                                "required": true,
                                "description": "Per-atom annotated LAMMPS dump produced by an upstream structure-identification step."
                            },
                            {
                                "name": "clustersTable",
                                "required": true,
                                "cliFlag": "--clusters_table",
                                "description": "Cluster graph table produced by an upstream structure-identification step (PTM/ACNA/PSM)."
                            },
                            {
                                "name": "clustersTransitions",
                                "required": true,
                                "cliFlag": "--clusters_transitions",
                                "description": "Cluster transitions table produced by an upstream structure-identification step."
                            },
                            {
                                "name": "neighborLattice",
                                "required": true,
                                "cliFlag": "--neighbor_lattice",
                                "description": "Per-atom neighbor topology parquet (neighbor_indices_* + neighbor_lattice_*) produced by an upstream structure-identification step (PTM/ACNA/PSM)."
                            }
                        ]
                    }
                }
            },
            {
                "id": "primary-exposure",
                "type": "exposure",
                "position": {
                    "x": 2016,
                    "y": 208
                },
                "data": {
                    "exposure": {
                        "name": "Dislocations",
                        "icon": "HiCube",
                        "results": "dislocations.parquet",
                        "iterable": "",
                        "properties": [
                            {
                                "key": "burgers_family",
                                "label": "Burgers family",
                                "type": "string"
                            },
                            {
                                "key": "burgers_family_label",
                                "label": "Burgers family (label)",
                                "type": "string"
                            },
                            {
                                "key": "crystal_structure",
                                "label": "Crystal structure",
                                "type": "string"
                            },
                            {
                                "key": "length",
                                "label": "Segment length",
                                "type": "number"
                            },
                            {
                                "key": "magnitude",
                                "label": "Burgers magnitude",
                                "type": "number"
                            },
                            {
                                "key": "cluster_id",
                                "label": "Cluster",
                                "type": "number"
                            }
                        ]
                    }
                }
            },
            {
                "id": "primary-export",
                "type": "export",
                "position": {
                    "x": 2336,
                    "y": 208
                },
                "data": {
                    "export": {
                        "exporter": "LineExporter",
                        "type": "glb",
                        "options": {
                            "lineWidth": 0.8,
                            "colorBy": "burgers_family",
                            "propertyColors": {
                                "Other": [
                                    0.9,
                                    0.2,
                                    0.2,
                                    1.0
                                ],
                                "1/2<110>": [
                                    0.2,
                                    0.2,
                                    1.0,
                                    1.0
                                ],
                                "1/6<112>": [
                                    0.0,
                                    1.0,
                                    0.0,
                                    1.0
                                ],
                                "1/6<110>": [
                                    1.0,
                                    0.0,
                                    1.0,
                                    1.0
                                ],
                                "1/3<100>": [
                                    1.0,
                                    1.0,
                                    0.0,
                                    1.0
                                ],
                                "1/3<111>": [
                                    0.0,
                                    1.0,
                                    1.0,
                                    1.0
                                ],
                                "1/2<111>": [
                                    0.2,
                                    0.95,
                                    0.2,
                                    1.0
                                ],
                                "<100>": [
                                    1.0,
                                    0.3,
                                    0.8,
                                    1.0
                                ],
                                "<110>": [
                                    0.2,
                                    0.5,
                                    1.0,
                                    1.0
                                ],
                                "<111>": [
                                    1.0,
                                    0.8,
                                    0.2,
                                    1.0
                                ],
                                "1/3<1-210>": [
                                    0.0,
                                    1.0,
                                    0.0,
                                    1.0
                                ],
                                "1/3<1-100>": [
                                    1.0,
                                    0.0,
                                    1.0,
                                    1.0
                                ],
                                "<0001>": [
                                    1.0,
                                    0.3,
                                    0.8,
                                    1.0
                                ],
                                "1/2<0001>": [
                                    1.0,
                                    1.0,
                                    0.0,
                                    1.0
                                ],
                                "1/3<1-213>": [
                                    0.0,
                                    1.0,
                                    1.0,
                                    1.0
                                ]
                            },
                            "material": {
                                "metallic": 0,
                                "roughness": 0.8,
                                "emissive": [
                                    0,
                                    0,
                                    0
                                ],
                                "baseColor": [
                                    1,
                                    0.5,
                                    0,
                                    1
                                ]
                            }
                        }
                    }
                }
            },
            {
                "id": "defect-mesh-exposure",
                "type": "exposure",
                "position": {
                    "x": 2016,
                    "y": 344
                },
                "data": {
                    "exposure": {
                        "name": "Defect Mesh",
                        "icon": "HiCube",
                        "results": "defect_mesh.parquet",
                        "iterable": ""
                    }
                }
            },
            {

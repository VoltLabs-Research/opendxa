                "data": {
                    "export": {
                        "exporter": "ChartExporter",
                        "type": "chart-png",
                        "options": {
                            "xAxisKey": "burgers_lengths.burgers_vector",
                            "yAxisKey": "burgers_lengths.total_length",
                            "chartType": "bar",
                            "title": "Dislocation length by Burgers vector",
                            "xAxisLabel": "Burgers vector",
                            "yAxisLabel": "Total length",
                            "backgroundColor": "#ffffff",
                            "lineColor": "#16a34a",
                            "fillColor": "rgba(22, 163, 74, 0.35)",
                            "showLegend": false,
                            "showGrid": true
                        }
                    }
                }
            },
            {
                "id": "network-statistics-exposure",
                "type": "exposure",
                "position": {

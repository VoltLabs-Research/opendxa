        "position": {
          "x": 2336,
          "y": 208
        },
        "data": {
          "export": {
            "exporter": "DislocationExporter",
            "type": "glb",
            "options": {
              "lineWidth": 0.8,
              "colorByType": true,
              "material": {
                "metallic": 0,
                "roughness": 0.8,
                "emissive": [

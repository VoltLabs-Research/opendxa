                },
                "data": {
                    "exposure": {
                        "name": "Burgers Length Distribution",
                        "icon": "HiChartBar",
                        "results": "dislocation_summary.parquet",
                        "iterable": "",
                        "hasListing": false
                    }
                }
            },
            {
                "id": "burgers-lengths-chart-export",
                "type": "export",
                "position": {
                    "x": 2032,
                    "y": 976
